  "sounds": [
    {
      "id": "g-ch",
      "name": "g/ch",
      "dutchName": "De harde g",
      "description": "The guttural Dutch g/ch sound",
      "ipa": "\u0263 / x",
      "difficulty": 5,
      "tips": [
        "Like clearing your throat gently",
        "Vibrate the back of your throat for 'g', unvoiced for 'ch'",
        "Think of the Scottish 'loch' but stronger",
        "The voiced version (\u0263) is used at the start of words, the unvoiced (x) at the end"
      ],
      "commonMistake": "Making it too soft like English 'g'",
      "practiceWords": [
        { "word": "goed", "ipa": "\u0263ut", "meaning": "good", "audio_hint": "Start with throat friction" },
        { "word": "nacht", "ipa": "n\u0251xt", "meaning": "night", "audio_hint": "Unvoiced at the end" },
        { "word": "gracht", "ipa": "\u0263r\u0251xt", "meaning": "canal", "audio_hint": "Both g and ch in one word!" },
        { "word": "acht", "ipa": "\u0251xt", "meaning": "eight", "audio_hint": "Strong ch at the end" },
        { "word": "gezellig", "ipa": "\u0263\u0259\u02c8z\u025bl\u0259x", "meaning": "cozy/fun", "audio_hint": "Voiced g at start, unvoiced at end" },
        { "word": "lachen", "ipa": "\u02c8l\u0251x\u0259n", "meaning": "to laugh", "audio_hint": "ch in the middle" },
        { "word": "nog", "ipa": "n\u0254x", "meaning": "still/yet", "audio_hint": "Final g sounds like ch" },
        { "word": "groot", "ipa": "\u0263rot", "meaning": "big/great", "audio_hint": "Voiced g followed by r" },
        { "word": "geen", "ipa": "\u0263en", "meaning": "no/none", "audio_hint": "Sustained throat vibration" },
        { "word": "lichaam", "ipa": "\u02c8l\u026axa\u02d0m", "meaning": "body", "audio_hint": "Unvoiced ch in the middle" }
      ],
      "minimalPairs": [
        { "pair": ["geel", "heel"], "meaning": ["yellow", "whole/very"] },
        { "pair": ["gat", "hat"], "meaning": ["hole", "(English) hat"] },
        { "pair": ["weg", "we"], "meaning": ["road/away", "we"] }
      ],
      "sentences": [
        { "text": "Goede morgen!", "meaning": "Good morning!" },
        { "text": "De gracht is heel mooi.", "meaning": "The canal is very beautiful." },
        { "text": "Acht nachten in een gezellig hotel.", "meaning": "Eight nights in a cozy hotel." },
        { "text": "Geen groot probleem.", "meaning": "No big problem." }
